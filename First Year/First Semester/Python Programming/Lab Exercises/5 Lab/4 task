class Person:
    def __init__(self, name, family, age, nationality,):
        self.name = name
        self.family = family
        self.age = age
        self.nationality = nationality

    def introduce(self):
        print(f'Hello I am {self.name}.')

    def print(self):
        print(f'Hello I am {self.name} {self.family}, I am {self.nationality}.')

class Student(Person):
