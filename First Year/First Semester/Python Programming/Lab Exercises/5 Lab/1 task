class Person:
    def __init__(self, name, age, city):
        self.name = name
        self.age = age
        self.city = city

    def print(self):
        print(f"Name: {self.name} {self.age}; City: {self.city}")

person1=Person('John', 30, 'Sofia')
person1.print()

person2=Person('Mike', 31, 'Plovdiv')
person2.print()

