from exmp import customer1


class Car:
    def __init__(self, id, brand, model, year, rent_per_day, mileage, fuel_type, licence_category,availability):
        self.id = id
        self.brand = brand
        self.model = model
        self.year = year
        self.rent_per_day = rent_per_day #price vmesto rent
        self.mileage = mileage
        self.fuel_type = fuel_type
        self.licence_category = licence_category
        self.availability = "available"

    def __str__(self):
        return (f'Information:\n Brand:{self.brand}\n Model:{self.model}\n Year:{self.year}\n Rent:{self.rent_per_day}\n'
        f' Mileage:{self.mileage}\n Fuel type:{self.fuel_type}\n Licence:{self.licence_category}\n Availability:{self.availability}')

    def is_available(self):
        return self.availability if self.availability == "available" else 'This car is not available'

    def total_rent(self):
        return self.rent_per_day

