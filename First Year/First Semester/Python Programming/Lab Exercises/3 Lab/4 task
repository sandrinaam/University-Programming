#Напишете програма в коята потр въвежда текст на негова база се създажа речник.
#За ключове на речника служат символите от текста а стоиността на елементите
# се определя от броя на елем (колко пъти)

text = input()
dictionary = {}

for char in text:
    dictionary[char]= text.count(char)

print(dictionary)

